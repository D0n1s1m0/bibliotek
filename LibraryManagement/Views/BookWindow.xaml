<Window x:Class="LibraryManagement.Views.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=" " Height="679" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Цветовая схема -->
        <Color x:Key="PrimaryDark">#1E1E2E</Color>
        <Color x:Key="PrimaryLight">#2D2D3A</Color>
        <Color x:Key="AccentPurple">#9B59B6</Color>
        <Color x:Key="AccentBlue">#3498DB</Color>
        <Color x:Key="AccentGreen">#2ECC71</Color>
        <Color x:Key="AccentRed">#E74C3C</Color>
        <Color x:Key="TextLight">#F5F5F5</Color>
        <Color x:Key="TextMuted">#95A5A6</Color>

        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLight}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="{StaticResource AccentPurple}" Offset="0"/>
            <GradientStop Color="{StaticResource AccentBlue}" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="WindowShadow" BlurRadius="30" Opacity="0.3" ShadowDepth="5"/>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5,0,0,5"/>
        </Style>

        <Style x:Key="FieldTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLightBrush}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PrimaryDarkBrush}"
            CornerRadius="20"
            Margin="20,20,20,-31"
            Effect="{StaticResource WindowShadow}">

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderGradient}"
                    CornerRadius="15"
                    Padding="20"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="📖" FontSize="28" Margin="0,0,15,0"/>
                    <!-- ИСПРАВЛЕНО: используем Title (свойство с new) -->
                    <TextBlock Grid.Column="1" Text="{Binding Title}" 
                               FontSize="20" FontWeight="Bold" Foreground="White" 
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="2" Content="✕" Width="32" Height="32"
                            Background="#40FFFFFF" Foreground="White" FontSize="16"
                            FontWeight="Bold" Cursor="Hand" BorderThickness="0"
                            Click="CancelButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1" Text="ОСНОВНАЯ ИНФОРМАЦИЯ" Style="{StaticResource SectionHeaderStyle}"/>

            <!-- Название -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="Название книги" Style="{StaticResource FieldLabelStyle}"/>
                <TextBox Text="{Binding CurrentBook.Title, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldTextBoxStyle}"/>
            </StackPanel>

            <!-- Год и количество -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Год издания" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding CurrentBook.PublishYear}" Style="{StaticResource FieldTextBoxStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Количество" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding CurrentBook.QuantityInStock}" Style="{StaticResource FieldTextBoxStyle}"/>
                </StackPanel>
            </Grid>

            <!-- ISBN -->
            <TextBlock Grid.Row="4" Text="ISBN (10 или 13 цифр)" Style="{StaticResource SectionHeaderStyle}"/>

            <StackPanel Grid.Row="5" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding CurrentBook.ISBN, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FieldTextBoxStyle}"/>

                    <Border Grid.Column="1" Background="{Binding IsbnValidationColor}"
                            CornerRadius="8" Width="40" Height="40" Margin="10,0,0,0">
                        <TextBlock Text="{Binding IsbnValidationIcon}" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                <TextBlock Text="{Binding IsbnValidationMessage}" 
                           Foreground="{Binding IsbnValidationMessageColor}"
                           FontSize="11" Margin="5,5,0,0"/>
            </StackPanel>

            <!-- Авторы -->
            <TextBlock Grid.Row="6" Text="АВТОРЫ" Style="{StaticResource SectionHeaderStyle}"/>

            <Grid Grid.Row="7" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding SelectedAuthorsDisplay, Mode=OneWay}"
                         IsReadOnly="True" Background="#252535" Style="{StaticResource FieldTextBoxStyle}"/>

                <Button Grid.Column="1" Content="✎" Command="{Binding SelectAuthorsCommand}"
                        Background="{StaticResource AccentPurpleBrush}" Style="{StaticResource SmallButtonStyle}"
                        Margin="10,0,0,0"/>
            </Grid>

            <!-- Жанры -->
            <TextBlock Grid.Row="8" Text="ЖАНРЫ" Style="{StaticResource SectionHeaderStyle}" Margin="0,15,0,-21"/>

            <Grid Grid.Row="9" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding SelectedGenresDisplay, Mode=OneWay}"
                         IsReadOnly="True" Background="#252535" Style="{StaticResource FieldTextBoxStyle}"/>

                <Button Grid.Column="1" Content="✎" Command="{Binding SelectGenresCommand}"
                        Background="{StaticResource AccentBlueBrush}" Style="{StaticResource SmallButtonStyle}"
                        Margin="10,0,0,0"/>
            </Grid>

            <!-- Кнопки -->
            <Grid Grid.Row="10" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" 
        Content="💾 Сохранить" 
        Click="SaveButton_Click" 
                    Background="{StaticResource AccentGreenBrush}" 
        Foreground="White"
        Style="{StaticResource ModernButtonStyle}" 
        Padding="25,0" 
        Width="130"
        Margin="5" 
        IsEnabled="{Binding CanSave}"/>

                    <Button Grid.Column="2" Content="✕ Отмена" Click="CancelButton_Click"
                        Background="{StaticResource AccentRedBrush}" Foreground="White"
                        Style="{StaticResource ModernButtonStyle}" Padding="25,0" Width="130" Margin="10,56,0,0"/>
            </Grid>
        </Grid>
    </Border>
</Window>