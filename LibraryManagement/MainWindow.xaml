<Window x:Class="LibraryManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Bibliotek Pro" Height="1000" Width="1424"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- Цветовая схема -->
        <Color x:Key="BgPrimary">#0F172A</Color>
        <Color x:Key="BgSecondary">#1E293B</Color>
        <Color x:Key="BgCard">#334155</Color>
        <Color x:Key="Accent1">#FF6B6B</Color>
        <Color x:Key="Accent2">#4ECDC4</Color>
        <Color x:Key="Accent3">#FFE66D</Color>
        <Color x:Key="Accent4">#9B87F5</Color>
        <Color x:Key="TextPrimary">#F8FAFC</Color>
        <Color x:Key="TextSecondary">#94A3B8</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondary}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="Accent1Brush" Color="{StaticResource Accent1}"/>
        <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2}"/>
        <SolidColorBrush x:Key="Accent3Brush" Color="{StaticResource Accent3}"/>
        <SolidColorBrush x:Key="Accent4Brush" Color="{StaticResource Accent4}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

        <!-- Градиенты -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="{StaticResource Accent1}" Offset="0"/>
            <GradientStop Color="{StaticResource Accent4}" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="StatCardGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2D3748" Offset="0"/>
            <GradientStop Color="#1A202C" Offset="1"/>
        </LinearGradientBrush>

        <!-- Тени -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" Opacity="0.25" ShadowDepth="4" Direction="315"/>
        <DropShadowEffect x:Key="ButtonShadow" BlurRadius="15" Opacity="0.3" ShadowDepth="2"/>

        <!-- Стиль для карточек -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource StatCardGradient}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <!-- Стиль для статистики -->
        <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource ModernCardStyle}">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style x:Key="NeoButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect" Value="{StaticResource ButtonShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderBrush="White"
                                BorderThickness="0,0,0,3">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="6"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стили для разных типов кнопок -->
        <Style x:Key="PrimaryNeoButton" TargetType="Button" BasedOn="{StaticResource NeoButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Accent1Brush}"/>
        </Style>

        <Style x:Key="SecondaryNeoButton" TargetType="Button" BasedOn="{StaticResource NeoButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Accent2Brush}"/>
        </Style>

        <Style x:Key="TertiaryNeoButton" TargetType="Button" BasedOn="{StaticResource NeoButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Accent3Brush}"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style x:Key="QuaternaryNeoButton" TargetType="Button" BasedOn="{StaticResource NeoButtonStyle}">
            <Setter Property="Background" Value="{StaticResource Accent4Brush}"/>
        </Style>

        <Style x:Key="DarkNeoButton" TargetType="Button" BasedOn="{StaticResource NeoButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource BgSecondaryBrush}"/>
            <Setter Property="RowBackground" Value="{StaticResource BgPrimaryBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource Accent2Brush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent1Brush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent4Brush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgPrimaryBrush}"
            CornerRadius="30"
            Margin="20"
            Effect="{StaticResource CardShadow}">

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Хедер -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderGradient}"
                    CornerRadius="20"
                    Padding="20"
                    Margin="0,0,0,25">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Bibliotek Pro" 
                                   FontSize="36" 
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="neo · brutalism · library" 
                                   FontSize="14"
                                   Foreground="#E0E0FF"
                                   Opacity="0.9"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Кнопка закрытия -->
                    <Button Grid.Column="1"
                            Content="✕"
                            Width="45"
                            Height="45"
                            Background="#40FFFFFF"
                            Foreground="White"
                            FontSize="20"
                            FontWeight="Bold"
                            Cursor="Hand"
                            BorderThickness="0"
                            Command="{Binding CloseWindowCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- QUICK ACTIONS -->
            <Border Grid.Row="1" 
                    Style="{StaticResource ModernCardStyle}"
                    Margin="0,0,974,25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="⚡ QUICK ACTIONS"
                               Foreground="{StaticResource Accent2Brush}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <WrapPanel Grid.Row="1" HorizontalAlignment="Left">
                        <Button Content="📖 НОВАЯ КНИГА" 
                                Command="{Binding AddBookCommand}"
                                Style="{StaticResource PrimaryNeoButton}"
                                Width="130"/>

                        <Button Content="📝 РЕДАКТИРОВАТЬ" 
                                Command="{Binding EditBookCommand}"
                                Style="{StaticResource QuaternaryNeoButton}"
                                Width="130"/>

                        <Button Content="❌ УДАЛИТЬ" 
                                Command="{Binding DeleteBookCommand}"
                                Style="{StaticResource DarkNeoButton}"
                                Width="120"/>

                        <Button Content="👥 АВТОРЫ" 
                                Command="{Binding ManageAuthorsCommand}"
                                Style="{StaticResource SecondaryNeoButton}"
                                Width="100"/>

                        <Button Content="🔄 СИНХР." 
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource DarkNeoButton}"
                                Width="100"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Статистика TOTALS BOOKS / AUTHORS / GENRES -->
            <WrapPanel Grid.Row="1" 
                       HorizontalAlignment="Left" 
                       Margin="415,47,0,72">

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📊 TOTAL BOOKS" 
                                   Foreground="{StaticResource Accent2Brush}"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalBooksCount}" 
                                   FontSize="36" 
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="👥 AUTHORS" 
                                   Foreground="{StaticResource Accent3Brush}"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding AuthorsCount}" 
                                   FontSize="36" 
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🏷️ GENRES" 
                                   Foreground="{StaticResource Accent1Brush}"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding GenresCount}" 
                                   FontSize="36" 
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- FILTERS -->
            <Border Grid.Row="3" 
                    Style="{StaticResource ModernCardStyle}"
                    Margin="0,0,0,25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="🔎 FILTERS"
                               Foreground="{StaticResource Accent3Brush}"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search by title"/>

                        <TextBlock Grid.Column="1" 
                                   Text="by"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Margin="20,0"/>

                        <ComboBox Grid.Column="2" 
                                  ItemsSource="{Binding AuthorsForFilter}"
                                  SelectedItem="{Binding SelectedAuthor}"
                                  DisplayMemberPath="FullName"/>

                        <TextBlock Grid.Column="3" 
                                   Text="and"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Margin="20,0"/>

                        <ComboBox Grid.Column="4" 
                                  ItemsSource="{Binding GenresForFilter}"
                                  SelectedItem="{Binding SelectedGenre}"
                                  DisplayMemberPath="Name"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- BOOK CATALOG -->
            <Border Grid.Row="4" 
                    Style="{StaticResource ModernCardStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок таблицы -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource BgCardBrush}"
                            CornerRadius="16,16,0,0"
                            Padding="20" Margin="0,-25,0,25">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="📋"
                                       FontSize="16"
                                       Margin="0,0,10,0"/>

                            <TextBlock Grid.Column="1" 
                                       Text="BOOK CATALOG" 
                                       FontSize="14" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource Accent2Brush}" Margin="0,0,0,-18"/>
                        </Grid>
                    </Border>

                    <!-- Таблица -->
                    <DataGrid 
                              ItemsSource="{Binding Books}"
                              SelectedItem="{Binding SelectedBook}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Margin="0,25,0,25" Grid.RowSpan="2">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" 
                                                Binding="{Binding Id}" 
                                                Width="50"/>

                            <DataGridTextColumn Header="TITLE" 
                                                Binding="{Binding Title}" 
                                                Width="250"/>

                            <DataGridTextColumn Header="AUTHOR" 
                                                Binding="{Binding Author.FullName}" 
                                                Width="150"/>

                            <DataGridTextColumn Header="GENRE" 
                                                Binding="{Binding Genre.Name}" 
                                                Width="120"/>

                            <DataGridTextColumn Header="YEAR" 
                                                Binding="{Binding PublishYear}" 
                                                Width="70"/>

                            <DataGridTextColumn Header="ISBN" 
                                                Binding="{Binding ISBN}" 
                                                Width="130"/>

                            <DataGridTextColumn Header="STOCK" 
                                                Binding="{Binding QuantityInStock}" 
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style>
                                        <Setter Property="TextBlock.Foreground" 
                                                Value="{StaticResource Accent2Brush}"/>
                                        <Setter Property="TextBlock.FontWeight" 
                                                Value="Bold"/>
                                        <Setter Property="TextBlock.HorizontalAlignment" 
                                                Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Online статус -->
            <Border Grid.Row="5" 
                    Background="{StaticResource BgSecondaryBrush}"
                    CornerRadius="15"
                    Padding="15"
                    Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource Accent2Brush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Online" 
                               Foreground="{StaticResource Accent2Brush}"
                               FontSize="12"
                               FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>